[
    {
        "id": 1,
        "author": "李白",
        "image_url": "result_20260326_205557_c4f152b1.jpg",
        "poetry": {
            "title": "《故宫和玺彩绘》",
            "content": "金龙蟠柱玉阶前，\n宝殿生辉瑞气连。\n彩画千年传古法，\n皇家气象满宫垣。"
        },
        "created_at": "2026-03-29T10:00:00"
    },
    {
        "id": 2,
        "author": "杜甫",
        "image_url": "result_20260326_210819_1793b66a.jpg",
        "poetry": {
            "title": "《颐和园长廊》",
            "content": "长廊九曲绕湖山，\n彩绘斑斓映碧湾。\n苏式风格传雅韵，\n文人画意满人间。"
        },
        "created_at": "2026-03-29T10:30:00"
    },
    {
        "id": 3,
        "author": "王维",
        "image_url": "result_20260329_143213_4e18acab.jpg",
        "poetry": {
            "title": "《敦煌壁画》",
            "content": "飞天漫舞奏仙音，\n壁画千年色尚新。\n丝路文明传万古，\n莫高窟里见精神。"
        },
        "created_at": "2026-03-29T11:00:00"
    },
    {
        "id": 4,
        "author": "苏轼",
        "image_url": "result_20260329_143513_719d6974.jpg",
        "poetry": {
            "title": "《旋子彩画》",
            "content": "旋花纹转碧云间，\n青绿相间映画栏。\n古建精华传后世，\n匠心独运谱新篇。"
        },
        "created_at": "2026-03-29T11:30:00"
    },
    {
        "id": 5,
        "author": "李清照",
        "image_url": "result_20260329_144507_11892b0e.jpg",
        "poetry": {
            "title": "《苏式彩画》",
            "content": "山水楼台入画屏，\n苏式彩绘韵天成。\n江南风味浓如酒，\n笔底春风满院庭。"
        },
        "created_at": "2026-03-29T12:00:00"
    },
    {
        "id": 6,
        "author": "白居易",
        "image_url": "result_20260323_192655_24fe6ef9.jpg",
        "poetry": {
            "title": "《布达拉宫》",
            "content": "红山之上起巍峨，\n藏式彩绘艳若霞。\n佛法庄严通天地，\n高原圣境世人夸。"
        },
        "created_at": "2026-03-29T12:30:00"
    },
    {
        "id": 7,
        "author": "李商隐",
        "image_url": "result_20260326_205557_c4f152b1.jpg",
        "poetry": {
            "title": "《太和殿》",
            "content": "太和殿上彩云飞，\n和玺彩绘耀日晖。\n天子登临朝万国，\n皇家气象古今稀。"
        },
        "created_at": "2026-03-29T13:00:00"
    },
    {
        "id": 8,
        "author": "杜牧",
        "image_url": "result_20260326_210819_1793b66a.jpg",
        "poetry": {
            "title": "《颐和园》",
            "content": "昆明湖畔柳丝垂，\n彩绘长廊映日辉。\n昔日皇家游乐地，\n如今百姓共徘徊。"
        },
        "created_at": "2026-03-29T13:30:00"
    },
    {
        "id": 9,
        "author": "刘禹锡",
        "image_url": "result_20260329_143213_4e18acab.jpg",
        "poetry": {
            "title": "《莫高窟》",
            "content": "黄沙万里藏瑰宝，\n壁画千年彩未消。\n佛法无边传西域，\n莫高窟里见唐朝。"
        },
        "created_at": "2026-03-29T14:00:00"
    },
    {
        "id": 10,
        "author": "王昌龄",
        "image_url": "result_20260329_143513_719d6974.jpg",
        "poetry": {
            "title": "《天坛》",
            "content": "天坛祈谷祭苍天，\n旋子彩画映碧天。\n古柏参天迎远客，\n文明传承万万年。"
        },
        "created_at": "2026-03-29T14:30:00"
    },
    {
        "id": 11,
        "author": "李白",
        "image_url": "result_20260323_192655_24fe6ef9.jpg",
        "poetry": {
            "title": "《黄鹤楼》",
            "content": "故人西辞黄鹤楼，\n烟花三月下扬州。\n孤帆远影碧空尽，\n唯见长江天际流。"
        },
        "created_at": "2026-03-29T15:00:00"
    },
    {
        "id": 12,
        "author": "杜甫",
        "image_url": "result_20260329_144507_11892b0e.jpg",
        "poetry": {
            "title": "《春望》",
            "content": "国破山河在，\n城春草木深。\n感时花溅泪，\n恨别鸟惊心。"
        },
        "created_at": "2026-03-29T15:30:00"
    },
    {
        "id": 13,
        "author": "李白",
        "image_url": "result_20260329_143513_719d6974.jpg",
        "poetry": {
            "title": "《望庐山瀑布》",
            "content": "日照香炉生紫烟，\n遥看瀑布挂前川。\n飞流直下三千尺，\n疑是银河落九天。"
        },
        "created_at": "2026-03-29T16:00:00"
    },
    {
        "id": 14,
        "author": "苏轼",
        "image_url": "result_20260326_205557_c4f152b1.jpg",
        "poetry": {
            "title": "《水调歌头》",
            "content": "明月几时有，\n把酒问青天。\n不知天上宫阙，\n今夕是何年。"
        },
        "created_at": "2026-03-29T16:30:00"
    },
    {
        "id": 15,
        "author": "杜甫",
        "image_url": "result_20260329_143213_4e18acab.jpg",
        "poetry": {
            "title": "《茅屋为秋风所破歌》",
            "content": "八月秋高风怒号，\n卷我屋上三重茅。\n茅飞渡江洒江郊，\n高者挂罥长林梢。"
        },
